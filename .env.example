# ── LLM ───────────────────────────────────────────────────────────────────────
# Ollama API endpoint (default: local Ollama)
LLM_URL=http://localhost:11434/api/chat

# Model to use. Any Ollama-compatible model name.
# Lightweight options: phi3, mistral, gemma2
# Recommended: llama3
LLM_MODEL=llama3

# Request timeout in milliseconds (default: 5 minutes)
LLM_TIMEOUT_MS=300000

# Send format:json to constrain LLM output to valid JSON. Set to "false" to disable.
LLM_JSON_FORMAT=true

# Set to "true" to run the agent without a real LLM (canned responses for testing)
LLM_MOCK=false

# ── Tool cache ─────────────────────────────────────────────────────────────────
# How long a cached tool result stays valid (ms, default 5 min)
TOOL_CACHE_TTL_MS=300000

# Max agent turns before a cached result expires regardless of TTL
TOOL_CACHE_MAX_TURNS=20

# ── Observer ──────────────────────────────────────────────────────────────────
# Path to the auth file written by setup.sh (username:shadow_hash)
OBSERVER_AUTH_FILE=/home/nomadai/.observer_auth

# Bind address for the observer servers.
# Default: 127.0.0.1 (localhost only — use SSH tunnel from host).
# Set to the VM's host-only IP (e.g. 192.168.56.101) to allow direct access
# from your host machine on the same VirtualBox host-only network.
OBSERVER_BIND=127.0.0.1

# Ports (defaults shown)
OBSERVER_UI_PORT=3000
OBSERVER_WS_PORT=3001
OBSERVER_NC_PORT=3002

# NC CLI credentials (used for the telnet/netcat interface on NC_PORT)
OBSERVER_USER=nomad
OBSERVER_PASS=nomad

# WebSocket token — set by setup.sh, used by the browser UI to authenticate.
# Change this to a strong random value before exposing the WS port.
OBSERVER_WS_TOKEN=changeme
